# ---------------------------------------------------------------------------
# Environment variables for the Meridian Osteopathy website.
# Copy values into Netlify: Site settings → Environment variables.
# Do NOT commit filled-in secrets to git.
# ---------------------------------------------------------------------------

# Cloudflare Turnstile (bot protection on referral + careers forms)
# Get from https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SECRET_KEY=

# Supabase (service role; bypasses RLS — server-side only)
# Project settings → API → Project URL + service_role key
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (email notifications)
# https://resend.com/api-keys
RESEND_API_KEY=
# Optional: override who emails come FROM and go TO
# Must be a domain you've verified in Resend.
NOTIFY_FROM=Meridian Website <no-reply@meridianosteopathy.co.nz>
NOTIFY_TO=info@meridianosteopathy.co.nz
