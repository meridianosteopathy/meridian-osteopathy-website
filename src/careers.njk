---
layout: base.njk
title: Careers
description: "Join our team at Meridian Osteopathy. Osteopath jobs in Christchurch, New Zealand. Structured mentorship program and career growth."
---

<!-- Hero -->
<section class="hero" style="background-image: url('/images/hero-careers.jpg');">
</section>

{% include "breadcrumbs.njk" %}

<!-- About working here -->
<section class="section">
  <div class="container">
    <div class="careers-content">
      <h1 class="text-center">Join Our Team at Meridian Osteopathy</h1>

      <p>We're not just offering a job — we're inviting you to embark on a <strong>rewarding career journey</strong> within a supportive and visionary environment.</p>

      <div class="careers-expandable">
        <p>Whether you're a <strong>recent graduate</strong> or a <strong>seasoned practitioner</strong>, we welcome dedicated individuals who are passionate about making a real difference in people's lives.</p>

        <p>For acupuncturists, all applicants — whether based in New Zealand or overseas — must hold current registration with the <strong>Chinese Medicine Council of New Zealand (CMCNZ)</strong>, or be eligible to obtain it prior to commencing practice. This is a mandatory requirement and ensures the highest standard of care for our patients.</p>

        <p>At every stage, you'll benefit from <strong>continuous learning opportunities</strong>, a collaborative team environment, and the satisfaction of positively impacting our patients. Our remuneration packages are competitive and tailored to experience, and we offer <strong>relocation assistance</strong> for those moving to Christchurch. Overseas applicants are welcome — we can assist with guidance on CMCNZ registration, visa applications, and help you settle into Christchurch.</p>
      </div>

      <button class="careers-read-more-btn" aria-expanded="false">Read more <span class="careers-read-more-arrow">↓</span></button>
    </div>
  </div>
</section>

<!-- Current Vacancies -->
<section class="section section-light">
  <div class="container">
    <h2 class="text-center">Current Vacancies</h2>

    {% if careers.vacancies and careers.vacancies.length > 0 %}

      <p class="subtitle" style="margin-bottom: 32px;">We're hiring! See our open positions below and apply using the form further down the page.</p>

      <div class="vacancy-table">
        <div class="vacancy-table-header">
          <span>Position</span>
          <span>Type</span>
          <span style="text-align:left;">Requirements</span>
          <span></span>
        </div>
        {% for v in careers.vacancies %}
        <div class="vacancy-row">
          <span class="vacancy-title">{{ v.title }}</span>
          <span class="vacancy-type vacancy-type--{{ v.type | lower | replace(' ', '-') }}">{{ v.type }}</span>
          <span class="vacancy-requirements"><span class="vacancy-req-label">Requirements: </span>{{ v.requirements }}</span>
          <a href="#apply" class="btn btn-primary btn-careers vacancy-apply-btn" data-position="{{ v.title }}">Apply Now</a>
        </div>
        {% endfor %}
      </div>

    {% else %}

      <div class="vacancy-empty">
        <div class="vacancy-empty-icon">
          <svg viewBox="0 0 48 48" fill="none" stroke="var(--primary)" stroke-width="1.8" width="48" height="48">
            <circle cx="24" cy="24" r="20"/>
            <path d="M24 14v12M24 32v2"/>
          </svg>
        </div>
        <h3>No open positions right now</h3>
        <p>We don't have any active vacancies at the moment, but we'd still love to hear from you. If you're a passionate healthcare professional interested in joining the Meridian Osteopathy team, submit your CV below — we keep all expressions of interest on file and will reach out when a suitable opportunity arises.</p>
        <a href="#apply" class="btn btn-primary" style="margin-top: 8px;">Register Your Interest</a>
      </div>

    {% endif %}
  </div>
</section>

<!-- Application Form -->
<section class="section" id="apply">
  <div class="container text-center">
    <h2>Application Form</h2>
    <p class="subtitle">Apply or register your interest to work at Meridian Osteopathy</p>

    <form name="career-application" method="POST" action="/.netlify/functions/submit-career" enctype="multipart/form-data" class="form-container" style="text-align: left; margin-top: 32px;" onsubmit="return handleCareerSubmit(event)">
      <p class="hidden" style="display:none;" aria-hidden="true">
        <label>Don't fill this out if you're human: <input name="bot-field" tabindex="-1" autocomplete="off"></label>
      </p>

      <div class="form-group">
        <label>Applying Position <span class="required">*</span></label>
        {% if careers.vacancies and careers.vacancies.length > 0 %}
          <select name="applying-position" id="applying-position" required>
            <option value="" disabled selected>Select a position…</option>
            {% for v in careers.vacancies %}
              <option value="{{ v.title }}">{{ v.title }}</option>
            {% endfor %}
          </select>
        {% else %}
          <input type="hidden" name="applying-position" value="Expression of Interest">
          <select disabled>
            <option selected>Expression of Interest</option>
          </select>
        {% endif %}
      </div>

      <div class="form-group">
        <label>Name <span class="required">*</span></label>
        <input type="text" name="name" placeholder="Enter your name" required>
      </div>

      <div class="form-group">
        <label>Email <span class="required">*</span></label>
        <input type="email" name="email" placeholder="Enter your email" required>
      </div>

      <div class="form-group">
        <label>Phone <span class="required">*</span></label>
        <input type="tel" name="phone" placeholder="Enter your phone" required>
      </div>

      <div class="form-group">
        <label>I am a: <span class="required">*</span></label>
        <select name="applicant-type" required>
          <option value="" disabled selected>Select applicant type…</option>
          <option value="recent-graduate">Recent Graduate</option>
          <option value="experienced-osteopath">Experienced Osteopath</option>
          <option value="cmcnz-acupuncturist">CMCNZ Registered Acupuncturist</option>
          <option value="other">Other</option>
        </select>
      </div>

      <div class="form-group">
        <label>Message</label>
        <textarea name="message" placeholder="Your message..."></textarea>
      </div>

      <div class="file-uploads">
        <div class="form-group">
          <label>CV/Resume</label>
          <input type="file" name="cv" accept=".pdf,.doc,.docx">
        </div>
        <div class="form-group">
          <label>Cover Letter</label>
          <input type="file" name="cover-letter" accept=".pdf,.doc,.docx">
        </div>
      </div>

      <div class="cf-turnstile" data-sitekey="{{ site.turnstileSiteKey }}" style="margin: 16px auto 0; display: flex; justify-content: center;"></div>

      <div style="text-align: center; margin-top: 16px;">
        <button type="submit" class="btn btn-primary btn-careers">Submit Application</button>
        <p style="margin-top: 12px; font-size: 0.85rem; opacity: 0.75;">By submitting, you agree to our <a href="/privacy/">Privacy Policy</a>. Unsuccessful applications are retained for 12 months and then deleted.</p>
      </div>
    </form>

    <div id="career-thank-you" style="display:none; margin-top: 32px;">
      <div class="thank-you-card">
        <h2>Thank you for your application</h2>
        <p>We've received your application and will be in touch soon. For urgent questions, call us on <a href="tel:{{ site.phone }}">{{ site.phone }}</a>.</p>
      </div>
    </div>
  </div>
</section>

<script>
  function handleCareerSubmit(event) {
    event.preventDefault();
    var form = event.target;
    var submitBtn = form.querySelector('button[type="submit"]');
    if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Submitting…'; }

    var data = new FormData(form);

    fetch(form.action, {
      method: 'POST',
      body: data
    }).then(function(response) {
      if (response.ok) {
        form.style.display = 'none';
        var ty = document.getElementById('career-thank-you');
        ty.style.display = 'block';
        ty.scrollIntoView({ behavior: 'smooth', block: 'start' });
        return;
      }
      return response.json().catch(function() { return {}; }).then(function(err) {
        var msg = 'Sorry, something went wrong. Please try again or email us directly.';
        if (err && err.error === 'turnstile-failed') {
          msg = 'Security check failed. Please tick the "I\u2019m human" box and try again.';
        } else if (err && err.error === 'file-too-large') {
          msg = 'One of your files is over the 3MB limit. Please attach a smaller file.';
        } else if (err && err.error === 'file-type-not-allowed') {
          msg = 'Only PDF, DOC, or DOCX files are accepted.';
        }
        alert(msg);
        if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Submit Application'; }
        if (window.turnstile) { try { window.turnstile.reset(); } catch(e) {} }
      });
    }).catch(function() {
      alert('Sorry, something went wrong. Please try again or email us directly.');
      if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Submit Application'; }
    });
    return false;
  }
</script>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
