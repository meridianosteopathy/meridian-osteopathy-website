---
layout: base.njk
title: Home
description: "Meridian Osteopathy in Christchurch offers osteopathy, medical acupuncture and sports rehabilitation. ACC registered. No GP referral needed."
---

<!-- Hero -->
<section class="hero hero-home" style="background-image: url('{{ home.heroImage }}');">
  <div class="hero-content">
  </div>
</section>

<!-- Practitioners -->
<section class="section text-center">
  <div class="container">
    <h2>{{ home.practitionersHeading }}</h2>
    <p class="subtitle">{{ home.practitionersIntro }}</p>
    <div class="team-grid" style="margin-top: 32px; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); max-width: 960px;">
      {% for p in home.practitioners %}
      <div class="team-card">
        <div class="team-card-image" style="background-image: url('{{ p.photo }}');"></div>
        <div class="team-card-info">
          <h3>{{ p.name }}</h3>
          <p class="role">{{ p.role | safe }}</p>
        </div>
        <div class="team-card-actions">
          <a href="/book/">Book {{ p.name.split(" ")[0] }}</a>
          <a href="{{ p.profileUrl }}">View Profile</a>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- CTA Banner -->
<section class="cta-banner">
  <h2>{{ home.ctaHeading }}</h2>
  <p>{{ home.ctaSubtext }}</p>
  <a href="/book/" class="btn btn-outline">Book Now</a>
</section>

<!-- Services -->
<section class="section text-center">
  <div class="container">
    <div class="services-grid">
      {% for s in home.servicesIntro %}
      <div class="service-card">
        <div class="service-card-icon">
          {% if loop.index == 1 %}
          <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="32" cy="20" r="8"/><path d="M20 56V42a12 12 0 0124 0v14"/><path d="M26 32l-4 10m16-10l4 10"/>
          </svg>
          {% elif loop.index == 2 %}
          <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M32 8v48M24 20l8-12 8 12M20 32h24M24 44l8 12 8-12"/>
          </svg>
          {% else %}
          <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="32" cy="16" r="8"/><path d="M16 56l8-20 8 8 8-8 8 20"/><path d="M24 36l-8-4m24 4l8-4"/>
          </svg>
          {% endif %}
        </div>
        <h3>{{ s.title }}</h3>
        <p>{{ s.description }}</p>
        <a href="{{ s.url }}" class="btn btn-outline" style="font-size:0.85rem; padding:8px 20px;">Read more &rarr;</a>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Your First Visit -->
<section class="section section-light text-center">
  <div class="container">
    <h2>Your First Visit</h2>
    <div class="steps-grid">
      {% for step in home.firstVisitSteps %}
      <div class="step-card">
        <div class="step-number">{{ step.number }}</div>
        <h4>{{ step.title }}</h4>
        <p>{{ step.description }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Testimonials -->
<section class="section">
  <div class="container">
    <h2>{{ home.testimonialsHeading }}</h2>
    <div class="rating-summary">
      <span class="stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
      <span class="rating-text">{{ home.testimonialsRating }}</span>
    </div>
    <div class="testimonials-grid">
      {% for t in home.testimonials %}
      <div class="testimonial-card">
        <div class="stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <blockquote>"{{ t.quote }}"</blockquote>
        <p class="author">&mdash; {{ t.author }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- FAQ -->
<section id="faq" class="section section-light">
  <div class="container">
    <h2>Frequently Asked Questions</h2>
    <div class="faq-list">
      {% for f in home.faq %}
      <div class="faq-item">
        <button class="faq-question">{{ f.question }}</button>
        <div class="faq-answer"><p>{{ f.answer }}</p></div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

{% include "back-to-top.njk" %}
