---
layout: base.njk
title: Home
titleOverride: "Osteopathy, Acupuncture & Herbal Medicine — Meridian Osteopathy"
description: "Christchurch clinic offering osteopathy, acupuncture and herbal medicine. Hands-on care that blends Western osteopathy with traditional Chinese medicine."
---

<!-- Hero -->
<section class="hero hero-home" style="background-image: url('{{ home.heroImage }}'); --hero-mobile: url('{{ home.heroImageMobile }}');">
</section>

<!-- Primary H1 — describes the clinic's primary intent so AI engines and search have a keyword-aligned page anchor -->
<section class="section text-center" style="padding-bottom: 0;">
  <div class="container">
    <h1>Osteopathy, Acupuncture &amp; Herbal Medicine in Christchurch</h1>
    <p class="subtitle">Hands-on care that blends osteopathy with traditional Chinese medicine.</p>
  </div>
</section>

<!-- Practitioners -->
<section class="section text-center" style="padding-top: 40px;">
  <div class="container">
    <h2>Our Practitioners</h2>
    <p class="subtitle">{{ home.practitionersIntro }}</p>
    <div class="team-grid" style="margin-top: 32px; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); max-width: 960px;">
      {% for p in home.practitioners %}
      <div class="team-card">
        <div class="team-card-image" style="background-image: url('{{ p.photo }}');"></div>
        <div class="team-card-info">
          <h3>{{ p.name }}</h3>
          <p class="role">{{ p.role | safe }}</p>
        </div>
        <div class="team-card-actions">
          <a href="/book/">Book {{ p.firstName }}</a>
          <a href="{{ p.profileUrl }}">View Profile</a>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- CTA Banner -->
<section class="cta-banner">
  <h2>{{ home.ctaHeading }}</h2>
  <p>{{ home.ctaSubtext }}</p>
  <a href="/book/" class="btn btn-gold">Book Now</a>
</section>

<!-- Services -->
<section class="section text-center">
  <div class="container">
    <div class="services-grid">
      {% for s in home.servicesIntro %}
      <div class="service-card">
        <div class="service-card-icon">
          {% if loop.index == 1 %}
          <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="32" cy="20" r="8"/><path d="M20 56V42a12 12 0 0124 0v14"/>
          </svg>
          {% elif loop.index == 2 %}
          <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M32 8v48M24 20l8-12 8 12M20 32h24M24 44l8 12 8-12"/>
          </svg>
          {% else %}
          <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M32 56V24M20 32c0-8 12-20 12-20s12 12 12 20a12 12 0 01-24 0z"/>
          </svg>
          {% endif %}
        </div>
        <h3>{{ s.title }}</h3>
        <p>{{ s.description }}</p>
        <a href="{{ s.url }}" class="btn btn-outline" style="font-size:0.85rem; padding:8px 20px;">Read more &rarr;</a>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Your First Visit -->
<section class="section section-light text-center">
  <div class="container">
    <h2>Your First Visit</h2>
    <div class="steps-grid">
      {% for step in home.firstVisitSteps %}
      <div class="step-card">
        <div class="step-number">{{ step.number }}</div>
        <h4>{{ step.title }}</h4>
        <p>{{ step.description }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Testimonials -->
<section class="section">
  <div class="container">
    <h2>{{ home.testimonialsHeading }}</h2>
    <div class="rating-summary">
      <span class="stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
      <span class="rating-text">{{ home.testimonialsRating }}</span>
    </div>
    <div class="testimonials-grid">
      {% for t in home.testimonials %}
      {% if t.link %}
      <a href="{{ t.link }}" target="_blank" rel="noopener noreferrer" class="testimonial-card testimonial-card--linked">
      {% else %}
      <div class="testimonial-card">
      {% endif %}
        <div class="stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <blockquote>"{{ t.quote }}"</blockquote>
        <p class="author">&mdash; {{ t.author }}</p>
        {% if t.link %}<p class="testimonial-google-link">Read on Google ↗</p>{% endif %}
      {% if t.link %}
      </a>
      {% else %}
      </div>
      {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<!-- FAQ -->
<section id="faq" class="section section-light">
  <div class="container">
    <h2>Frequently Asked Questions</h2>
    <div class="faq-list">
      {% for f in home.faq %}
      <div class="faq-item">
        <button class="faq-question">{{ f.question }}</button>
        <div class="faq-answer"><p>{{ f.answer }}</p></div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Catchment-suburb signal — names the suburbs we serve so AI search and local queries can match -->
<section class="section text-center" style="padding-top: 32px; padding-bottom: 32px;">
  <div class="container">
    <p class="subtitle" style="margin: 0;">Serving Hillmorton, Halswell, Addington, Sydenham, Wigram and surrounding Christchurch suburbs.</p>
  </div>
</section>

{% include "back-to-top.njk" %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for f in home.faq %}
    {
      "@type": "Question",
      "name": {{ f.question | dump | safe }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ f.answer | dump | safe }}
      }
    }{% if not loop.last %},{% endif %}
    {%- endfor %}
  ]
}
</script>

