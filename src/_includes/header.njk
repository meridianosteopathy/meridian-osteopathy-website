      <ul>
        <li><a href="/" {% if page.url == "/" %}class="active"{% endif %}>Home</a></li>
        <li class="has-dropdown">
          <a href="#" class="dropdown-trigger" {% if page.url and "/services/" in page.url %}class="active"{% endif %}>Services</a>
          <ul class="dropdown">
            <li><a href="/services/osteopathy/">Osteopathy</a></li>
            <li><a href="/services/acupuncture/">Acupuncture</a></li>
            <li><a href="/services/herbal-medicine/">Herbal Medicine</a></li>
          </ul>
        </li>
        <li class="has-dropdown">
          <a href="#" class="dropdown-trigger" {% if page.url and "/team/" in page.url %}class="active"{% endif %}>Team</a>
          <ul class="dropdown">
            <li><a href="/team/nina-hu/">Na (Nina) Hu</a></li>
            <li><a href="/team/jonathan-grice/">Jonathan Grice</a></li>
            <li><a href="/team/maddison-moffat/">Maddison Moffat</a></li>
            <li><a href="/team/min-jin/">Min Jin</a></li>
          </ul>
        </li>
        <li><a href="/careers/" {% if page.url == "/careers/" %}class="active"{% endif %}>Career</a></li>
        <li><a href="/referral/" {% if page.url == "/referral/" %}class="active"{% endif %}>Referral</a></li>
        <li><a href="/contact/" {% if page.url == "/contact/" %}class="active"{% endif %}>Contact</a></li>
      </ul>
