    <div class="mobile-menu-logo-bg" aria-hidden="true">
      <img src="/images/logomark-dark.svg" alt="">
    </div>
    <nav class="mobile-nav">
      <ul>
        <li><a href="/" {% if page.url == "/" %}class="active"{% endif %}>Home</a></li>

        <li class="mobile-has-dropdown">
          <button class="mobile-dropdown-trigger" aria-expanded="false">
            <span>Services</span>
            <svg class="mobile-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"/>
