<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  {%- set pageTitle = titleOverride or (title + " | " + site.name) %}
  {%- set pageDescription = description or "Meridian Osteopathy - Christchurch osteopathy, acupuncture and herbal medicine. ACC registered. No GP referral needed." %}
  {%- set pageUrl = site.url + page.url %}
  {%- set pageImage = site.url + (ogImage or "/images/social-card.jpg") %}
  <title>{{ pageTitle }}</title>
  <meta name="description" content="{{ pageDescription }}">
  <link rel="canonical" href="{{ pageUrl }}">

  <!-- Open Graph (Facebook, LinkedIn, iMessage, Slack, WhatsApp) -->
  <meta property="og:type" content="{{ ogType or 'website' }}">
  <meta property="og:site_name" content="{{ site.name }}">
  <meta property="og:title" content="{{ pageTitle }}">
  <meta property="og:description" content="{{ pageDescription }}">
  <meta property="og:url" content="{{ pageUrl }}">
  <meta property="og:locale" content="en_NZ">
  <meta property="og:image" content="{{ pageImage }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="{{ ogImageAlt or 'Meridian Osteopathy' }}">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ pageTitle }}">
  <meta name="twitter:description" content="{{ pageDescription }}">
  <meta name="twitter:image" content="{{ pageImage }}">
  <meta name="twitter:image:alt" content="{{ ogImageAlt or 'Meridian Osteopathy' }}">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <!-- Baskervville: secondary brand typeface (free from Google Fonts) -->
  <link href="https://fonts.googleapis.com/css2?family=Baskervville:ital@0;1&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <link rel="icon" href="/images/logomark-dark.svg" type="image/svg+xml">
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  {%- if site.metaPixelId %}
  <!-- Meta Pixel -->
  <script>
    !function(f,b,e,v,n,t,s)
    {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
    n.callMethod.apply(n,arguments):n.queue.push(arguments)};
    if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
    n.queue=[];t=b.createElement(e);t.async=!0;
    t.src=v;s=b.getElementsByTagName(e)[0];
    s.parentNode.insertBefore(t,s)}(window, document,'script',
    'https://connect.facebook.net/en_US/fbevents.js');
    fbq('init', '{{ site.metaPixelId }}');
    fbq('track', 'PageView');
  </script>
  <noscript><img height="1" width="1" style="display:none"
    src="https://www.facebook.com/tr?id={{ site.metaPixelId }}&ev=PageView&noscript=1"
    alt=""/></noscript>
  <!-- End Meta Pixel -->
  {%- endif %}
  {%- set addressBlock %}
        {
          "@type": "PostalAddress",
          "streetAddress": {{ site.addressParts.streetAddress | dump | safe }},
          "addressLocality": {{ site.addressParts.locality | dump | safe }},
          "postalCode": {{ site.addressParts.postalCode | dump | safe }},
          "addressRegion": {{ site.addressParts.region | dump | safe }},
          "addressCountry": {{ site.addressParts.countryCode | dump | safe }}
        }
  {%- endset %}
  {%- set areaBlock %}
        {
          "@type": "City",
          "name": {{ site.areaServed | dump | safe }},
          "containedInPlace": {
            "@type": "Country",
            "name": {{ site.addressParts.country | dump | safe }}
          }
        }
  {%- endset %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "MedicalClinic",
        "@id": "{{ site.url }}/#clinic",
        "name": {{ site.name | dump | safe }},
        "url": "{{ site.url }}/",
        "telephone": {{ site.phoneE164 | dump | safe }},
        "email": {{ site.email | dump | safe }},
        "priceRange": {{ site.priceRange | dump | safe }},
        "address": {{ addressBlock | safe }},
        "areaServed": {{ areaBlock | safe }},
        "openingHoursSpecification": [
          {%- for h in site.hoursSchema %}
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": {{ h.days | dump | safe }},
            "opens": {{ h.opens | dump | safe }},
            "closes": {{ h.closes | dump | safe }}
          }{% if not loop.last %},{% endif %}
          {%- endfor %}
        ]
      },
      {
        "@type": "MedicalBusiness",
        "@id": "{{ site.url }}/#business",
        "name": {{ site.name | dump | safe }},
        "url": "{{ site.url }}/",
        "telephone": {{ site.phoneE164 | dump | safe }},
        "priceRange": {{ site.priceRange | dump | safe }},
        "address": {{ addressBlock | safe }},
        "areaServed": {{ areaBlock | safe }},
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Clinic Services",
          "itemListElement": [
            {%- for key, s in services %}
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "MedicalTherapy",
                "name": {{ s.title | dump | safe }},
                "url": "{{ site.url }}{{ s.url }}"
              }
            }{% if not loop.last %},{% endif %}
            {%- endfor %}
          ]
        }
      }
    ]
  }
  </script>
</head>
<body>
  {% include "header.njk" %}
  <main>
    {{ content | safe }}
  </main>
  {% include "footer.njk" %}
  <script src="/js/main.js"></script>
  <script>
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", user => {
        if (!user) {
          window.netlifyIdentity.on("login", () => {
            document.location.href = "/admin/";
          });
        }
      });
    }
  </script>
</body>
</html>
