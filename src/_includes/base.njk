<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  {%- set pageTitle = titleOverride or (title + " | " + site.name) %}
  {%- set pageDescription = description or "Christchurch clinic offering osteopathy, acupuncture and herbal medicine. Hands-on care that blends Western osteopathy with traditional Chinese medicine." %}
  {%- set pageUrl = site.url + page.url %}
  {%- set pageImage = site.url + (ogImage or "/images/social-card.jpg") %}
  {%- set pageModified = updated or page.date %}
  {%- set crumbs = page.url | breadcrumbs %}
  <title>{{ pageTitle }}</title>
  <meta name="description" content="{{ pageDescription }}">
  <link rel="canonical" href="{{ pageUrl }}">

  <!-- Open Graph (Facebook, LinkedIn, iMessage, Slack, WhatsApp) -->
  <meta property="og:type" content="{{ ogType or 'website' }}">
  <meta property="og:site_name" content="{{ site.name }}">
  <meta property="og:title" content="{{ pageTitle }}">
  <meta property="og:description" content="{{ pageDescription }}">
  <meta property="og:url" content="{{ pageUrl }}">
  <meta property="og:locale" content="en_NZ">
  <meta property="og:image" content="{{ pageImage }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="{{ ogImageAlt or 'Meridian Osteopathy' }}">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ pageTitle }}">
  <meta name="twitter:description" content="{{ pageDescription }}">
  <meta name="twitter:image" content="{{ pageImage }}">
  <meta name="twitter:image:alt" content="{{ ogImageAlt or 'Meridian Osteopathy' }}">

  <link rel="stylesheet" href="/css/styles.css">
  {%- if heroPreload %}
  <!-- Preload the LCP hero image so the browser fetches it as early as it fetches the CSS. -->
  <link rel="preload" as="image" fetchpriority="high" href="{{ heroPreload }}">
  {%- endif %}
  <link rel="icon" href="/images/logomark-dark.svg" type="image/svg+xml">
  {%- if site.gaMeasurementId %}
  <!-- Google Analytics (production only; gated in src/_data/site.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id={{ site.gaMeasurementId }}"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '{{ site.gaMeasurementId }}');
  </script>
  {%- endif %}
  {%- set addressBlock %}
        {
          "@type": "PostalAddress",
          "streetAddress": {{ site.addressParts.streetAddress | dump | safe }},
          "addressLocality": {{ site.addressParts.locality | dump | safe }},
          "postalCode": {{ site.addressParts.postalCode | dump | safe }},
          "addressRegion": {{ site.addressParts.region | dump | safe }},
          "addressCountry": {{ site.addressParts.countryCode | dump | safe }}
        }
  {%- endset %}
  {%- set areaBlock %}
        {
          "@type": "City",
          "name": {{ site.areaServed | dump | safe }},
          "containedInPlace": {
            "@type": "Country",
            "name": {{ site.addressParts.country | dump | safe }}
          }
        }
  {%- endset %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "MedicalClinic",
        "@id": "{{ site.url }}/#clinic",
        "name": {{ site.name | dump | safe }},
        "url": "{{ site.url }}/",
        "telephone": {{ site.phoneE164 | dump | safe }},
        "email": {{ site.email | dump | safe }},
        "priceRange": {{ site.priceRange | dump | safe }},
        "address": {{ addressBlock | safe }},
        "areaServed": {{ areaBlock | safe }},
        "openingHoursSpecification": [
          {%- for h in site.hoursSchema %}
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": {{ h.days | dump | safe }},
            "opens": {{ h.opens | dump | safe }},
            "closes": {{ h.closes | dump | safe }}
          }{% if not loop.last %},{% endif %}
          {%- endfor %}
        ]
      },
      {
        "@type": "MedicalBusiness",
        "@id": "{{ site.url }}/#business",
        "name": {{ site.name | dump | safe }},
        "url": "{{ site.url }}/",
        "telephone": {{ site.phoneE164 | dump | safe }},
        "priceRange": {{ site.priceRange | dump | safe }},
        "address": {{ addressBlock | safe }},
        "areaServed": {{ areaBlock | safe }},
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": {{ home.googleReviews.ratingValue | dump | safe }},
          "reviewCount": {{ home.googleReviews.reviewCount | dump | safe }},
          "bestRating": {{ home.googleReviews.bestRating | dump | safe }},
          "worstRating": {{ home.googleReviews.worstRating | dump | safe }}
        },
        "review": [
          {%- for t in home.testimonials %}
          {
            "@type": "Review",
            "reviewRating": {
              "@type": "Rating",
              "ratingValue": "5",
              "bestRating": "5"
            },
            "author": {
              "@type": "Person",
              "name": {{ t.author | dump | safe }}
            },
            "reviewBody": {{ t.quote | dump | safe }}{% if t.link %},
            "url": {{ t.link | dump | safe }}{% endif %}
          }{% if not loop.last %},{% endif %}
          {%- endfor %}
        ],
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Clinic Services",
          "itemListElement": [
            {%- for key, s in services %}
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "MedicalTherapy",
                "name": {{ s.title | dump | safe }},
                "url": "{{ site.url }}{{ s.url }}"
              }
            }{% if not loop.last %},{% endif %}
            {%- endfor %}
          ]
        }
      },
      {
        "@type": "WebPage",
        "@id": "{{ pageUrl }}#webpage",
        "url": "{{ pageUrl }}",
        "name": {{ pageTitle | dump | safe }},
        "description": {{ pageDescription | dump | safe }},
        "isPartOf": { "@id": "{{ site.url }}/#clinic" },
        "inLanguage": "en-NZ",
        "dateModified": "{{ pageModified | dateIso }}"
      }{%- if crumbs.length %},
      {
        "@type": "BreadcrumbList",
        "@id": "{{ pageUrl }}#breadcrumbs",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "{{ site.url }}/"
          }{%- for c in crumbs %},
          {
            "@type": "ListItem",
            "position": {{ loop.index + 1 }},
            "name": {{ c.name | dump | safe }},
            "item": "{{ site.url }}{{ c.url }}"
          }{%- endfor %}
        ]
      }{%- endif %}
    ]
  }
  </script>
</head>
<body>
  {% include "header.njk" %}
  <main>
    {{ content | safe }}
    {%- if updated %}
    <div class="last-updated">
      <div class="container">
        <p>Last updated: {{ updated | dateFriendly }}</p>
      </div>
    </div>
    {%- endif %}
  </main>
  {% include "footer.njk" %}
  <script src="/js/main.js"></script>
</body>
</html>
