<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | {{ site.name }}</title>
  <meta name="description" content="{{ description or 'Meridian Osteopathy - Christchurch osteopathy, acupuncture and herbal medicine. ACC registered. No GP referral needed.' }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <!-- Baskervville: secondary brand typeface (free from Google Fonts) -->
  <link href="https://fonts.googleapis.com/css2?family=Baskervville:ital@0;1&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "MedicalClinic",
        "@id": "https://meridianosteopathy.co.nz/#clinic",
        "name": "{{ site.name }}",
        "url": "https://meridianosteopathy.co.nz/",
        "telephone": "+64-21-086-55151",
        "email": "{{ site.email }}",
        "priceRange": "$80–$120",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "21 Coppell Place, Hillmorton",
          "addressLocality": "Christchurch",
          "postalCode": "8025",
          "addressRegion": "Canterbury",
          "addressCountry": "NZ"
        },
        "areaServed": {
          "@type": "City",
          "name": "Christchurch",
          "containedInPlace": {
            "@type": "Country",
            "name": "New Zealand"
          }
        },
        "openingHoursSpecification": [
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
            "opens": "09:00",
            "closes": "19:00"
          },
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": "Saturday",
            "opens": "09:00",
            "closes": "13:00"
          }
        ]
      },
      {
        "@type": "MedicalBusiness",
        "@id": "https://meridianosteopathy.co.nz/#business",
        "name": "{{ site.name }}",
        "url": "https://meridianosteopathy.co.nz/",
        "telephone": "+64-21-086-55151",
        "priceRange": "$80–$120",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "21 Coppell Place, Hillmorton",
          "addressLocality": "Christchurch",
          "postalCode": "8025",
          "addressRegion": "Canterbury",
          "addressCountry": "NZ"
        },
        "areaServed": {
          "@type": "City",
          "name": "Christchurch",
          "containedInPlace": {
            "@type": "Country",
            "name": "New Zealand"
          }
        },
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Clinic Services",
          "itemListElement": [
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "MedicalTherapy",
                "name": "Osteopathy",
                "url": "https://meridianosteopathy.co.nz/services/osteopathy/"
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "MedicalTherapy",
                "name": "Acupuncture",
                "url": "https://meridianosteopathy.co.nz/services/acupuncture/"
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "MedicalTherapy",
                "name": "Herbal Medicine",
                "url": "https://meridianosteopathy.co.nz/services/herbal-medicine/"
              }
            }
          ]
        }
      }
    ]
  }
  </script>
</head>
<body>
  {% include "header.njk" %}
  <main>
    {{ content | safe }}
  </main>
  {% include "footer.njk" %}
  <script src="/js/main.js"></script>
  <script>
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", user => {
        if (!user) {
          window.netlifyIdentity.on("login", () => {
            document.location.href = "/admin/";
          });
        }
      });
    }
  </script>
</body>
</html>
