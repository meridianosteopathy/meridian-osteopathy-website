<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | {{ site.name }}</title>
  <meta name="description" content="{{ description or 'Meridian Osteopathy - Christchurch osteopathy, acupuncture and herbal medicine. ACC registered. No GP referral needed.' }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <!-- Baskervville: secondary brand typeface (free from Google Fonts) -->
  <link href="https://fonts.googleapis.com/css2?family=Baskervville:ital@0;1&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  {%- set addressBlock %}
        {
          "@type": "PostalAddress",
          "streetAddress": {{ site.addressParts.streetAddress | dump | safe }},
          "addressLocality": {{ site.addressParts.locality | dump | safe }},
          "postalCode": {{ site.addressParts.postalCode | dump | safe }},
          "addressRegion": {{ site.addressParts.region | dump | safe }},
          "addressCountry": {{ site.addressParts.countryCode | dump | safe }}
        }
  {%- endset %}
  {%- set areaBlock %}
        {
          "@type": "City",
          "name": {{ site.areaServed | dump | safe }},
          "containedInPlace": {
            "@type": "Country",
            "name": {{ site.addressParts.country | dump | safe }}
          }
        }
  {%- endset %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "MedicalClinic",
        "@id": "{{ site.url }}/#clinic",
        "name": {{ site.name | dump | safe }},
        "url": "{{ site.url }}/",
        "telephone": {{ site.phoneE164 | dump | safe }},
        "email": {{ site.email | dump | safe }},
        "priceRange": {{ site.priceRange | dump | safe }},
        "address": {{ addressBlock | safe }},
        "areaServed": {{ areaBlock | safe }},
        "openingHoursSpecification": [
          {%- for h in site.hoursSchema %}
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": {{ h.days | dump | safe }},
            "opens": {{ h.opens | dump | safe }},
            "closes": {{ h.closes | dump | safe }}
          }{% if not loop.last %},{% endif %}
          {%- endfor %}
        ]
      },
      {
        "@type": "MedicalBusiness",
        "@id": "{{ site.url }}/#business",
        "name": {{ site.name | dump | safe }},
        "url": "{{ site.url }}/",
        "telephone": {{ site.phoneE164 | dump | safe }},
        "priceRange": {{ site.priceRange | dump | safe }},
        "address": {{ addressBlock | safe }},
        "areaServed": {{ areaBlock | safe }},
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Clinic Services",
          "itemListElement": [
            {%- for key, s in services %}
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "MedicalTherapy",
                "name": {{ s.title | dump | safe }},
                "url": "{{ site.url }}{{ s.url }}"
              }
            }{% if not loop.last %},{% endif %}
            {%- endfor %}
          ]
        }
      }
    ]
  }
  </script>
</head>
<body>
  {% include "header.njk" %}
  <main>
    {{ content | safe }}
  </main>
  {% include "footer.njk" %}
  <script src="/js/main.js"></script>
  <script>
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", user => {
        if (!user) {
          window.netlifyIdentity.on("login", () => {
            document.location.href = "/admin/";
          });
        }
      });
    }
  </script>
</body>
</html>
