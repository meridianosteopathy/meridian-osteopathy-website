<!-- Profile Hero -->
<section class="profile-hero">
  <div class="profile-hero-content">
    <h1>{{ member.name }}</h1>
    <p class="profile-subtitle">{{ member.role | safe }}</p>
  </div>
</section>

{% include "breadcrumbs.njk" %}

<!-- Profile Body -->
<section class="profile-body">
  <div class="profile-main">

    <!-- Left: Info Cards -->
    <div class="profile-content">

      <div class="profile-card">
        <div class="profile-card-header">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342"/></svg>
          <h3>Qualifications &amp; Background</h3>
        </div>
        {{ member.qualifications | safe }}
      </div>

      <div class="profile-card">
        <div class="profile-card-header">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z"/></svg>
          <h3>My Treatment Approach</h3>
        </div>
        <p>{{ member.approach }}</p>
      </div>

      <div class="profile-card">
        <div class="profile-card-header">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6Zm0 9.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25Zm9.75-9.75A2.25 2.25 0 0 1 15.75 3.75H18a2.25 2.25 0 0 1 2.25 2.25v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6Zm0 9.75a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 15.75V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z"/></svg>
          <h3>Special Interests</h3>
        </div>
        <p>{{ member.specialInterests }}</p>
      </div>

      <div class="profile-card">
        <div class="profile-card-header">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/></svg>
          <h3>About Me</h3>
        </div>
        <p>{{ member.aboutMe }}</p>
      </div>

    </div>

    <!-- Right: Photo & Booking -->
    <div class="profile-sidebar">
      <div class="profile-photo-card">
        <img src="{{ member.photo }}" alt="{{ member.name }}" loading="lazy">
        <div class="profile-booking-info">
          <h4>{{ member.name }}</h4>
          <p class="profile-credentials">{{ member.role | safe }}</p>
          <a href="/book/" class="btn-book-profile">Book {{ member.firstName }}</a>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- From Consultation to Recovery -->
<section class="profile-steps">
  <h2>From Consultation to Recovery</h2>
  <div class="profile-steps-list">
    {% for step in (member.consultationSteps or team.consultationSteps) %}
    <div class="profile-step">
      <span class="profile-step-number">{{ step.number }}</span>
      <div>
        <h3>{{ step.title }}</h3>
        <p>{{ step.description }}</p>
      </div>
    </div>
    {% endfor %}
  </div>
</section>

<!-- Practitioner structured data — Physician schema tells AI search engines
     this page is a qualified healthcare professional, which is a 2026 E-E-A-T
     ranking signal for YMYL content. -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Physician",
  "@id": "{{ site.url }}{{ page.url }}#practitioner",
  "name": {{ member.name | dump | safe }},
  "jobTitle": {{ member.role | plain | dump | safe }},
  "url": "{{ site.url }}{{ page.url }}",
  "image": "{{ site.url }}{{ member.photo }}",
  "worksFor": { "@id": "{{ site.url }}/#clinic" },
  "description": {{ member.approach | dump | safe }}{% if member.sameAs %},
  "sameAs": {{ member.sameAs | dump | safe }}{% endif %}{% if member.medicalSpecialty %},
  "medicalSpecialty": {{ member.medicalSpecialty | dump | safe }}{% endif %}
}
</script>
