<footer class="site-footer">
  <div class="footer-main">
    <div class="footer-container">
      <div class="footer-brand">
        <a href="/" class="logo">
          <img src="/images/logo-primary-light.svg" alt="Meridian Osteopathy" class="logo-img" width="160" height="44">
        </a>
        <div class="acc-badge">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6.5 12L2 7.5l1.5-1.5L6.5 9 12.5 3 14 4.5 6.5 12z" fill="#4CAF50"/></svg>
          <span>ACC approved provider</span>
        </div>
      </div>

      <nav class="footer-nav">
        <a href="/book/" class="footer-book-link">Book Now</a>

        <a href="/contact/">Contact</a>
        <a href="/careers/">Careers</a>
        <a href="/referral/">Referral</a>
        <a href="/#faq">FAQs</a>
      </nav>

      <div class="footer-contact">
        <a href="tel:{{ site.phone }}" class="footer-phone">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          {{ site.phone }}
        </a>
        <a href="mailto:{{ site.email }}" class="footer-email">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          info@meridianosteopathy.co.nz
        </a>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="footer-container">
      <p>&copy; 2026, Meridian Osteopathy Ltd <span aria-hidden="true" style="margin: 0 6px; opacity: 0.4;">·</span> <a href="/privacy/">Privacy Policy</a></p>
      {% if site.social.facebook or site.social.instagram or site.social.linkedin or site.social.youtube %}
      <div class="social-links">
        {% if site.social.facebook %}
        <a href="{{ site.social.facebook }}" aria-label="Facebook" target="_blank" rel="noopener">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
        </a>
        {% endif %}
        {% if site.social.instagram %}
        <a href="{{ site.social.instagram }}" aria-label="Instagram" target="_blank" rel="noopener">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
        {% endif %}
        {% if site.social.linkedin %}
        <a href="{{ site.social.linkedin }}" aria-label="LinkedIn" target="_blank" rel="noopener">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2zM4 6a2 2 0 100-4 2 2 0 000 4z"/></svg>
        </a>
        {% endif %}
        {% if site.social.youtube %}
        <a href="{{ site.social.youtube }}" aria-label="YouTube" target="_blank" rel="noopener">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 11.75a29 29 0 00.46 5.33A2.78 2.78 0 003.4 19.1c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 001.94-2 29 29 0 00.46-5.25 29 29 0 00-.46-5.33z"/><polygon points="9.75,15.02 15.5,11.75 9.75,8.48" fill="white"/></svg>
        </a>
        {% endif %}
      </div>
      {% endif %}
    </div>
  </div>
</footer>
