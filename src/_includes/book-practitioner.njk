<section class="hero" style="background-image: url('/images/hero-book.jpg');">
</section>

{% include "breadcrumbs.njk" %}

<section class="section">
  <div class="container text-center">
    <h1>Book with {{ member.firstName }}</h1>
    <p style="max-width: 720px; margin: 16px auto 0; font-size: 1.05rem;">
      Book an appointment online with {{ member.name }}, {{ member.role | plain }} at Meridian Osteopathy in Hillmorton.{% if not member.noAcc and not member.cannotLodgeAcc %} ACC claims can be lodged at your first visit.{% endif %}
    </p>
    <ul style="max-width: 720px; margin: 16px auto 0; text-align: left; padding-left: 24px;">
      <li>Choose your service and time slot in the booking widget below.</li>
      <li>You'll receive an email confirmation immediately after booking.</li>
      {% if not member.noAcc %}{% if member.cannotLodgeAcc %}<li>If your visit relates to an injury covered by ACC, please bring your existing ACC claim number — {{ member.firstName }} can treat you under your active claim. To lodge a new claim, please book one of our osteopaths first.</li>{% else %}<li>If your visit relates to an injury covered by ACC, please bring your ACC claim number if you have one — otherwise our osteopath can lodge a new claim at your first appointment.</li>{% endif %}{% endif %}
    </ul>
    {% if member.cannotLodgeAcc %}
    <p style="max-width: 720px; margin: 16px auto 0; font-size: .9rem; font-style: italic; opacity: 0.8;">
      Note for ACC patients: ACC funds up to 12 acupuncture sessions within a 12-week window from your first appointment with {{ member.firstName }}, and your injury must be less than 12 months old. If you've already used those sessions or the window has closed, {{ member.firstName }} can request additional cover from ACC with clinical evidence. <a href="https://www.acc.co.nz/newsroom/stories/changes-to-acupuncture-treatment/" target="_blank" rel="noopener external">Source: ACC</a>.
    </p>
    {% endif %}
    <div style="max-width: 800px; margin: 32px auto 0;">
      <iframe id='cliniko-25867357' src='https://meridian-osteopathy.au2.cliniko.com/bookings?practitioner_id={{ member.bookingPractitionerId }}&embedded=true' frameborder='0' scrolling='auto' width='100%' height='1000' style='pointer-events: auto;'></iframe>
      <script type='text/javascript'>
        window.addEventListener('message', function handleIFrameMessage (e) {
          var clinikoBookings = document.getElementById('cliniko-25867357');
          if (typeof e.data !== 'string') return;
          if (e.data.search('cliniko-bookings-resize') > -1) {
            var height = Number(e.data.split(':')[1]);
            clinikoBookings.style.height = height + 'px';
          }
          e.data.search('cliniko-bookings-page') > -1 && clinikoBookings.scrollIntoView();
        });
      </script>
    </div>
    <p style="max-width: 720px; margin: 32px auto 0; font-size: .95rem;">
      <a href="/book/">&larr; Book with a different practitioner</a>
    </p>
  </div>
</section>
