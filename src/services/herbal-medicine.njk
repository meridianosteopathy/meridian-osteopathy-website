---
layout: base.njk
title: Herbal Medicine
description: "Herbal medicine at Meridian Osteopathy Christchurch — personalised Chinese herbal prescriptions for pain, stress, digestive health, and hormonal balance."
---

{% set s = services.herbs %}

<!-- Hero -->
<section class="hero" style="background-image: url('{{ s.heroImage }}');">
</section>

<!-- Introduction -->
<section class="section text-center">
  <div class="container">
    <div class="service-intro">
      <h1>{{ s.title }}</h1>
      <p>{{ s.intro }}</p>
    </div>
  </div>
</section>

<!-- Pricing -->
<section class="section section-light">
  <div class="container">
    <h2>Pricing</h2>
    <div class="pricing-cards">
      <div class="pricing-card">
        <div class="pricing-card-label">Coming Soon</div>
        <div class="pricing-card-rate pricing-card-rate--variable">More info<br>on the way</div>
        <div class="pricing-card-time">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          Stay tuned
        </div>
      </div>
      <div class="pricing-card-divider"></div>
      <div class="pricing-card">
        <div class="pricing-card-label">Herbal Prescription</div>
        <div class="pricing-card-rate pricing-card-rate--variable">Quoted on<br>consultation</div>
        <div class="pricing-card-time">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M12 2a9 9 0 0 1 0 18M12 2a9 9 0 0 0 0 18M12 2v18M2 9h20M2 15h20"/></svg>
          Varies by formula
        </div>
      </div>
    </div>
    <div class="pricing-note-box">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18" style="flex-shrink:0;margin-top:2px;"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
      <p>Herbal prescription costs are separate from the consultation fee and vary depending on the herbs selected, the complexity of your formula, and the duration of your treatment. Your practitioner will provide a full quote during your appointment.</p>
    </div>
  </div>
</section>

<!-- Specialties intro -->
<section class="section text-center">
  <div class="container">
    <h2>What Herbal Medicine Can Treat</h2>
    <p class="subtitle">Personalised plant-based formulas designed to support your body from the inside out.</p>
  </div>
</section>

<!-- Specialty blocks -->
{% for spec in s.specialties %}
<section class="section {% if loop.index is even %}section-light{% endif %} specialty-section">
  <div class="container">
    <div class="specialty-block {% if loop.index is even %}specialty-block--reverse{% endif %}">
      <div class="specialty-image">
        {% if spec.image %}
        <img src="{{ spec.image }}" alt="{{ spec.title }}">
        {% else %}
        <div class="specialty-image-placeholder">
          <span>Image coming soon</span>
        </div>
        {% endif %}
      </div>
      <div class="specialty-content">
        <h2>{{ spec.title }}</h2>
        <p>{{ spec.description }}</p>
        <a href="/book/" class="btn btn-gold">Book Now</a>
      </div>
    </div>
  </div>
</section>
{% endfor %}

<!-- Other Services -->
<section class="section text-center">
  <div class="container">
    <h2>Explore Our Other Services</h2>
    <div class="other-services">
      <a href="/services/osteopathy/" class="other-service-card">
        <div class="icon">
          <svg viewBox="0 0 64 64" fill="none" stroke="var(--primary)" stroke-width="2" width="50" height="50">
            <circle cx="32" cy="20" r="8"/><path d="M20 56V42a12 12 0 0124 0v14"/>
          </svg>
        </div>
        <div>
          <h3>Osteopathy</h3>
          <span class="btn btn-outline" style="font-size:0.85rem; padding:6px 16px;">Learn more &rarr;</span>
        </div>
      </a>
      <a href="/services/acupuncture/" class="other-service-card">
        <div class="icon">
          <svg viewBox="0 0 64 64" fill="none" stroke="var(--primary)" stroke-width="2" width="50" height="50">
            <path d="M32 8v48M24 20l8-12 8 12M20 32h24M24 44l8 12 8-12"/>
          </svg>
        </div>
        <div>
          <h3>Acupuncture</h3>
          <span class="btn btn-outline" style="font-size:0.85rem; padding:6px 16px;">Learn more &rarr;</span>
        </div>
      </a>
    </div>
  </div>
</section>

{% include "back-to-top.njk" %}
