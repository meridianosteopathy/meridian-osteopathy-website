---
layout: base.njk
title: Acupuncture for Fertility & IVF Support
permalink: /services/acupuncture/fertility/
description: "Fertility-focused acupuncture in Christchurch. IVF and natural conception support with Nina Hu — Postgraduate Certificate in Health Science (Acupuncture), integrating osteopathy and traditional Chinese medicine."
---

{% set s = services.acupuncture.fertility %}

<!-- Hero -->
<section class="hero" style="background-image: url('{{ s.heroImage }}');">
</section>

{% include "breadcrumbs.njk" %}

<!-- Introduction -->
<section class="section text-center">
  <div class="container">
    <div class="service-intro">
      <h1>{{ s.title }}</h1>
      <p>{{ s.intro }}</p>
    </div>
  </div>
</section>

<!-- Pricing -->
<section class="section section-light">
  <div class="container">
    <h2>Pricing</h2>
    <div class="pricing-cards pricing-cards--single">
      <div class="pricing-card">
        <div class="pricing-card-label">Non-ACC Patient</div>
        <div class="pricing-card-rate">{{ site.pricing.private.rate }}</div>
        <div class="pricing-card-time">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          40 – 60 minutes
        </div>
      </div>
    </div>
    <div class="pricing-note-box">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18" style="flex-shrink:0;margin-top:2px;"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
      <p>Fertility and IVF support sits outside ACC cover, since it isn't accident-related. If you also have an ACC injury, that part of your care can still be claimed separately.</p>
    </div>
  </div>
</section>

<!-- Specialty blocks -->
{% for spec in s.sections %}
<section class="section {% if loop.index is even %}section-light{% endif %} specialty-section">
  <div class="container">
    <div class="specialty-block {% if loop.index is even %}specialty-block--reverse{% endif %}">
      <div class="specialty-image">
        {% if spec.image %}
        <img src="{{ spec.image }}" alt="{{ spec.title }}">
        {% else %}
        <div class="specialty-image-placeholder">
          <span>Image coming soon</span>
        </div>
        {% endif %}
      </div>
      <div class="specialty-content">
        <h2>{{ spec.title }}</h2>
        <p>{{ spec.description }}</p>
        <a href="/book/" class="btn btn-gold">Book Now</a>
      </div>
    </div>
  </div>
</section>
{% endfor %}

<!-- FAQ -->
<section class="section section-light">
  <div class="container">
    <h2 class="text-center">Frequently Asked Questions</h2>
    <div class="faq-list">
      {% for f in s.faq %}
      <div class="faq-item">
        <button class="faq-question">{{ f.question }}</button>
        <div class="faq-answer"><p>{{ f.answer }}</p></div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Other Services -->
<section class="section text-center">
  <div class="container">
    <h2>Explore Our Other Services</h2>
    <div class="other-services">
      <a href="/services/acupuncture/" class="other-service-card">
        <div class="icon">
          <svg viewBox="0 0 64 64" fill="none" stroke="var(--primary)" stroke-width="2" width="50" height="50">
            <circle cx="32" cy="32" r="20"/><path d="M32 12v40M12 32h40"/>
          </svg>
        </div>
        <div>
          <h3>All Acupuncture Care</h3>
          <span class="btn btn-outline" style="font-size:0.85rem; padding:6px 16px;">Learn more &rarr;</span>
        </div>
      </a>
      <a href="/services/herbal-medicine/" class="other-service-card">
        <div class="icon">
          <svg viewBox="0 0 64 64" fill="none" stroke="var(--primary)" stroke-width="2" width="50" height="50">
            <path d="M32 56V24M20 32c0-8 12-20 12-20s12 12 12 20a12 12 0 01-24 0z"/>
          </svg>
        </div>
        <div>
          <h3>Herbal Medicine</h3>
          <span class="btn btn-outline" style="font-size:0.85rem; padding:6px 16px;">Learn more &rarr;</span>
        </div>
      </a>
    </div>
  </div>
</section>

{# Inline schema rather than service-schema.njk: this MedicalTherapy is a
   sub-service of the parent acupuncture entity and references its @id, which
   the shared include doesn't model. #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "MedicalTherapy",
  "@id": "{{ site.url }}{{ s.url }}#service",
  "name": {{ s.title | dump | safe }},
  "url": "{{ site.url }}{{ s.url }}",
  "description": {{ s.intro | dump | safe }},
  "mainEntityOfPage": { "@id": "{{ site.url }}{{ s.url }}#webpage" },
  "isPartOf": { "@id": "{{ site.url }}/services/acupuncture/#service" },
  "provider": { "@id": "{{ site.url }}/#clinic" },
  "areaServed": {
    "@type": "City",
    "name": {{ site.areaServed | dump | safe }},
    "containedInPlace": { "@type": "Country", "name": {{ site.addressParts.country | dump | safe }} }
  }
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": "{{ site.url }}{{ s.url }}#faq",
  "mainEntity": [
    {%- for f in s.faq %}
    {
      "@type": "Question",
      "name": {{ f.question | dump | safe }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ f.answer | dump | safe }}
      }
    }{% if not loop.last %},{% endif %}
    {%- endfor %}
  ]
}
</script>

{% include "back-to-top.njk" %}
