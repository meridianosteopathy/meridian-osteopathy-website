---
layout: base.njk
title: Osteopathy
description: "Osteopathy treatment at Meridian Osteopathy in Christchurch. ACC registered, no GP referral needed. Treating back pain, headaches, joint pain and more."
---

{% set s = services.osteopathy %}

<!-- Hero -->
<section class="hero" style="background-image: url('{{ s.heroImage }}');">
  <div class="hero-content">
    <h1>{{ s.title }}</h1>
  </div>
</section>

<!-- Introduction -->
<section class="section text-center">
  <div class="container">
    <div class="service-intro">
      <h2>{{ s.title }}</h2>
      <p>{{ s.intro }}</p>
    </div>
  </div>
</section>

<!-- Pricing -->
<section class="section section-light">
  <div class="container">
    <h2>Pricing</h2>
    <div class="pricing-table">
      <table>
        <thead>
          <tr>
            <th>Patient Type</th>
            <th>Rate</th>
            <th>Notes</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><span class="acc-tag">ACC</span> ACC Patient<span class="td-subnote">{{ site.pricing.acc.notes }}</span></td>
            <td class="pricing-rate">{{ site.pricing.acc.rate }}</td>
            <td class="pricing-notes-col">{{ site.pricing.acc.notes }}</td>
          </tr>
          <tr>
            <td>Private Patient<span class="td-subnote">{{ site.pricing.private.notes }}</span></td>
            <td class="pricing-rate">{{ site.pricing.private.rate }}</td>
            <td class="pricing-notes-col">{{ site.pricing.private.notes }}</td>
          </tr>
        </tbody>
      </table>
      <p class="pricing-note">* Pricing may vary slightly</p>
    </div>
  </div>
</section>

<!-- Techniques -->
<section class="section">
  <div class="container">
    <div class="techniques-list">
      <h2>{{ s.techniquesHeading }}</h2>
      <ul>
        {% for t in s.techniques %}<li>{{ t }}</li>{% endfor %}
      </ul>
    </div>
  </div>
</section>

<!-- Conditions Banner -->
<section class="conditions-banner">
  <div class="conditions-image" style="background-image: url('{{ s.conditionsImage }}');"></div>
  <div class="conditions-content">
    <h2>{{ s.conditionsHeading }}</h2>
    <ul>
      {% for c in s.conditions %}<li>{{ c }}</li>{% endfor %}
    </ul>
    <p class="conditions-note">{{ s.conditionsNote }}</p>
  </div>
</section>

<!-- Other Services -->
<section class="section text-center">
  <div class="container">
    <h2>Explore Our Other Services</h2>
    <div class="other-services">
      <a href="/services/medical-acupuncture/" class="other-service-card">
        <div class="icon">
          <svg viewBox="0 0 64 64" fill="none" stroke="var(--primary)" stroke-width="2" width="50" height="50">
            <path d="M32 8v48M24 20l8-12 8 12M20 32h24M24 44l8 12 8-12"/>
          </svg>
        </div>
        <div>
          <h3>Medical Acupuncture</h3>
          <span class="btn btn-outline" style="font-size:0.85rem; padding:6px 16px;">Learn more &rarr;</span>
        </div>
      </a>
      <a href="/services/sports-rehabilitation/" class="other-service-card">
        <div class="icon">
          <svg viewBox="0 0 64 64" fill="none" stroke="var(--primary)" stroke-width="2" width="50" height="50">
            <circle cx="32" cy="16" r="8"/><path d="M16 56l8-20 8 8 8-8 8 20"/>
          </svg>
        </div>
        <div>
          <h3>Sports Rehabilitation</h3>
          <span class="btn btn-outline" style="font-size:0.85rem; padding:6px 16px;">Learn more &rarr;</span>
        </div>
      </a>
    </div>
  </div>
</section>
