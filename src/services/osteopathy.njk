---
layout: base.njk
title: Osteopathy
description: "Osteopathy treatment at Meridian Osteopathy in Christchurch. ACC registered, no GP referral needed. Treating back pain, headaches, joint pain and more."
heroPreload: /images/hero-osteopathy.jpg
---

{% set s = services.osteopathy %}

<!-- Hero -->
<section class="hero" style="background-image: url('{{ s.heroImage }}');">
</section>

{% include "breadcrumbs.njk" %}

<!-- Introduction -->
<section class="section text-center">
  <div class="container">
    <div class="service-intro">
      <h1>{{ s.title }}</h1>
      <p>{{ s.intro }}</p>
      <p style="margin-top: 16px;">Read our condition guide on <a href="/conditions/neck-pain/">neck pain in Christchurch</a>.</p>
    </div>
  </div>
</section>

<!-- Pricing -->
<section class="section section-light">
  <div class="container">
    <h2>Pricing</h2>
    <div class="pricing-cards">
      <div class="pricing-card">
        <div class="pricing-card-label"><span class="acc-tag">ACC</span> ACC Patient</div>
        <div class="pricing-card-rate">{{ site.pricing.acc.rate }}</div>
        <div class="pricing-card-time">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          40 – 60 minutes
        </div>
      </div>
      <div class="pricing-card-divider"></div>
      <div class="pricing-card">
        <div class="pricing-card-label">Non-ACC Patient</div>
        <div class="pricing-card-rate">{{ site.pricing.private.rate }}</div>
        <div class="pricing-card-time">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          40 – 60 minutes
        </div>
      </div>
    </div>
    <div class="pricing-note-box">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18" style="flex-shrink:0;margin-top:2px;"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
      <p>If you've recently been injured and haven't made an ACC claim yet, our osteopath can help you lodge one.</p>
    </div>
  </div>
</section>

<!-- Specialties intro -->
<section class="section text-center">
  <div class="container">
    <h2>Osteopathy for Every Stage of Life</h2>
    <p class="subtitle">Our practitioners are experienced in treating patients at every age and stage — here's how osteopathy can help you.</p>
  </div>
</section>

<!-- Specialty blocks -->
{% for spec in s.specialties %}
<section class="section {% if loop.index is even %}section-light{% endif %} specialty-section">
  <div class="container">
    <div class="specialty-block {% if loop.index is even %}specialty-block--reverse{% endif %}">
      <div class="specialty-image">
        {% if spec.image %}
        <img src="{{ spec.image }}" alt="{{ spec.title }}">
        {% else %}
        <div class="specialty-image-placeholder">
          <span>Image coming soon</span>
        </div>
        {% endif %}
      </div>
      <div class="specialty-content">
        <h2>{{ spec.title }}</h2>
        <p>{{ spec.description }}</p>
        <a href="/book/" class="btn btn-gold">Book Now</a>
      </div>
    </div>
  </div>
</section>
{% endfor %}

<!-- Other Services -->
<section class="section text-center">
  <div class="container">
    <h2>Explore Our Other Services</h2>
    <div class="other-services">
      <a href="/services/acupuncture/" class="other-service-card">
        <div class="icon">
          <svg viewBox="0 0 64 64" fill="none" stroke="var(--primary)" stroke-width="2" width="50" height="50">
            <path d="M32 8v48M24 20l8-12 8 12M20 32h24M24 44l8 12 8-12"/>
          </svg>
        </div>
        <div>
          <h3>Acupuncture</h3>
          <span class="btn btn-outline" style="font-size:0.85rem; padding:6px 16px;">Learn more &rarr;</span>
        </div>
      </a>
      <a href="/services/herbal-medicine/" class="other-service-card">
        <div class="icon">
          <svg viewBox="0 0 64 64" fill="none" stroke="var(--primary)" stroke-width="2" width="50" height="50">
            <path d="M32 56V24M20 32c0-8 12-20 12-20s12 12 12 20a12 12 0 01-24 0z"/>
          </svg>
        </div>
        <div>
          <h3>Herbal Medicine</h3>
          <span class="btn btn-outline" style="font-size:0.85rem; padding:6px 16px;">Learn more &rarr;</span>
        </div>
      </a>
    </div>
  </div>
</section>

{% include "service-schema.njk" %}
{% include "back-to-top.njk" %}
